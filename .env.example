# Rapid Rise AI website — environment variables
# Copy to `.env.local` for local dev, and set the same keys in the Vercel project
# settings for production. NEVER commit real values.
#
# Two groups:
#   • VITE_*  → compiled into the browser bundle. PUBLIC. No secrets, ever.
#   • everything else → server-only (Vercel serverless functions in /api).
#     In a Vite app only VITE_-prefixed vars reach the client, so these stay
#     private. They must NOT be prefixed VITE_ (or NEXT_PUBLIC_).

# ── Client / build-time (PUBLIC — safe to expose) ─────────────────────────────
# Same-origin paths that switch the contact form + tracker from "off" (mailto
# fallback / no network) to "on" (calls the serverless routes). Leave UNSET to
# keep the current behaviour unchanged.
VITE_CONTACT_API=/api/contact
VITE_TRACK_API=/api/track

# ── Server-only (SECRET — never exposed to the browser) ───────────────────────
# The Supabase project that holds the CRM (affiliates / leads / tracking_code).
# NOTE: the project ref in the original brief (lakisdthcuejvazgsbxz) was not
# reachable from the connected MCP account — confirm the correct ref/URL here.
SUPABASE_URL=https://YOUR-CRM-PROJECT-REF.supabase.co

# Service-role key — full DB access. SERVER ONLY. Used exclusively inside /api.
SUPABASE_SERVICE_ROLE_KEY=

# Names of the Postgres RPCs the routes call. Defaults shown; override only if
# you name the functions differently in the migration.
WEBSITE_LEAD_RPC=submit_website_lead
AFFILIATE_CLICK_RPC=record_website_referral_click

# Optional: server-side HMAC secret used to derive a non-reversible visitor token
# for click de-duplication WITHOUT storing raw IP/user-agent. Leave blank to skip
# fingerprinting entirely (recommended default — matches the site's privacy stance).
AFFILIATE_ATTRIBUTION_HMAC_SECRET=

# Optional: team email notification on a new lead (Resend). Leave blank to skip;
# a notification failure never fails a submission whose lead was already stored.
RESEND_API_KEY=
INTERNAL_NOTIFICATION_EMAIL=team@rapidriseai.com
NOTIFICATION_FROM=Rapid Rise AI <team@rapidriseai.com>
